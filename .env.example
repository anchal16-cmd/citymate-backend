# Copy this file to .env and fill in your real values.
# Never commit the real .env file to git.

# Get your FREE Gemini API key (no credit card needed) from:
# https://aistudio.google.com/app/apikey
# Sign in with any Google account, click "Create API key", copy it here.
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model Mia uses.
# gemini-2.5-flash       -> fast, free tier: 10 requests/min, 250/day (default)
# gemini-2.5-flash-lite  -> even higher free-tier limits, slightly less capable
GEMINI_MODEL=gemini-2.5-flash

# Port the backend server listens on
PORT=5000

# The origin your frontend is served from (Live Server / http-server / etc.)
# Update this to match wherever you actually run the CityMate frontend.
CORS_ORIGIN=http://localhost:3000 
