# Copy this file to .env and fill in your real values.
# Never commit the real .env file to git.

# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Which Claude model Mia uses.
# claude-haiku-4-5-20251001  -> fastest & cheapest, great for a FAQ-style support bot (default)
# claude-sonnet-5            -> smarter, a bit slower/costlier, use if Mia needs to reason more
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Port the backend server listens on
PORT=5000

# The origin your frontend is served from (Live Server / http-server / etc.)
# Update this to match wherever you actually run the CityMate frontend.
CORS_ORIGIN=http://127.0.0.1:5500
